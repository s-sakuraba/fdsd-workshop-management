@model Fdsd.Domain.Entities.M_Gakka
@{
    ViewData["Title"] = "Create";
}
<h3>学科登録</h3>
<a href="@Url.Action("Index")" class="btn btn-sm btn-secondary mb-2">戻る</a>
<div class="col-sm-2">
    <a href="@Url.Action("Index")" class="btn btn-sm btn-secondary">戻る</a>
</div>
<hr />
@Html.ValidationSummary(true, "", new { @class = "text-danger" })

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="form-horizontal">
        <div class="form-group">
            <label class="control-label col-md-2">学科コード</label>
            <div class="col-md-10">
                <input name="gakkaCd" type="number" class="form-control" style="max-width:280px;" required />
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">学科名</label>
            <div class="col-md-10">
                <input name="gakkaName" class="form-control" style="max-width:280px;" required />
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">略称</label>
            <div class="col-md-10">
                <input name="gakkaRyaku" class="form-control" style="max-width:280px;" />
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">FDSD区分</label>
            <div class="col-md-10">
                <input name="fdsdCd" type="number" class="form-control" style="max-width:280px;" />
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <button type="submit" class="btn btn-outline-dark">登録</button>
            </div>
        </div>
    </div>
</form>

<div>
    <a href="@Url.Action("Index")" class="btn btn-sm btn-secondary">戻る</a>
</div>