@model Fdsd.Domain.Entities.M_Gakka
@{
    ViewData["Title"] = "Details";
}
<div>
    <h3>学科詳細</h3>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            学科名
        </dt>
        <dd>
            @Model.GAKKANAME
        </dd>
        <dt>
            略称
        </dt>
        <dd>
            @Model.GAKKARYAKU
        </dd>
        <dt>
            FDSD区分
        </dt>
        <dd>
            @(Model.FDSDCD == 1 ? "SD" : "FD")
        </dd>
    </dl>
</div>
<p>
    <a href="@Url.Action("Edit", new { id = Model.GAKKACD })" class="btn btn-outline-dark">編集</a> |
    <a href="@Url.Action("Index")" class="btn btn-secondary">戻る</a>
</p>