@model Fdsd.Domain.Entities.M_Gakka
@{
    ViewData["Title"] = "Edit";
}
<h3>学科編集</h3>
<hr />
@Html.ValidationSummary(true, "", new { @class = "text-danger" })
<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.GAKKACD" />

    <div class="form-horizontal">
        <div class="form-group">
            <label class="control-label col-md-2">学科名</label>
            <div class="col-md-10">
                <input name="gakkaName" value="@Model.GAKKANAME" class="form-control" style="max-width:280px;" required />
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">略称</label>
            <div class="col-md-10">
                <input name="gakkaRyaku" value="@Model.GAKKARYAKU" class="form-control" style="max-width:280px;" />
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">FDSD区分</label>
            <div class="col-md-10">
                <input name="fdsdCd" type="number" value="@Model.FDSDCD" class="form-control" style="max-width:280px;" />
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <button type="submit" class="btn btn-outline-dark">編集</button>
            </div>
        </div>
    </div>
</form>

<div>
    <a href="@Url.Action("Index")" class="btn btn-sm btn-secondary">戻る</a>
</div>