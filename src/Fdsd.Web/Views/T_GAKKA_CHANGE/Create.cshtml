@{
    ViewData["Title"] = "Create";
    var gakkaList = (IEnumerable<Fdsd.Application.Common.GakkaDto>)ViewBag.GakkaList;
}
<h2>所属登録</h2>
<a href="@Url.Action("Index")" class="btn btn-sm btn-secondary mb-3">戻る</a>
<hr />
@Html.ValidationSummary(true, "", new { @class = "text-danger" })

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="form-horizontal">
        <div class="form-group">
            <label class="control-label col-md-2">異動対象者</label>
            <div class="col-md-10">
                <p class="form-control-plaintext">@ViewBag.UserName</p>
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">異動先学科</label>
            <div class="col-md-10">
                <select name="gakkaCd" class="form-select" style="max-width:280px;" required>
                    <option value="">-- 選択してください --</option>
                    @foreach (var g in gakkaList)
                    {
                        <option value="@g.GakkaCd">@g.GakkaName</option>
                    }
                </select>
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">DateOfArrival</label>
            <div class="col-md-10">
                <input type="date" name="dateOfArrival" value="@DateTime.Now.ToString("yyyy-MM-dd")" class="form-control" style="max-width:280px;" />
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">date_of_departure</label>
            <div class="col-md-10">
                <input type="date" name="dateOfDeparture" value="" class="form-control" style="max-width:280px;" />
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <button type="submit" class="btn btn-outline-dark">Create</button>
            </div>
        </div>
    </div>
</form>

<div>
    <a href="@Url.Action("Index")" class="btn btn-sm btn-secondary">戻る</a>
</div>