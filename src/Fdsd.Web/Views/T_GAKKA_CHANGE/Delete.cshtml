@model Fdsd.Application.Common.GakkaChangeDto
@{
    ViewData["Title"] = "Delete";
}
<h3>本当に削除してもよろしいですか?</h3>
<div>
    <h3>所属削除</h3>
    <div class="col-sm-2">
        <a href="@Url.Action("Index")" class="btn btn-sm btn-secondary">戻る</a>
    </div>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            教職員名
        </dt>
        <dd>
            @Model.EmpName
        </dd>
        <dt>
            学科名
        </dt>
        <dd>
            @Model.GakkaName
        </dd>
        <dt>
            所属開始日
        </dt>
        <dd>
            @Model.DateOfArrival.ToString("yyyy/MM/dd")
        </dd>
        <dt>
            所属終了日
        </dt>
        <dd>
            @Model.DateOfDeparture?.ToString("yyyy/MM/dd")
        </dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" name="id" value="@Model.Id" />

        <div class="form-actions no-color">
            <button type="submit" class="btn btn-outline-dark">削除</button> |
            <a href="@Url.Action("Index")" class="btn btn-sm btn-secondary">戻る</a>
        </div>
    </form>
</div>