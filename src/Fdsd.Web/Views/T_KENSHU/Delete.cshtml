@model Fdsd.Application.Common.KenshuDetailDto
@using Fdsd.Application.Common
@{
    ViewData["Title"] = "Delete";
}

<div class="container">
    <div class="row">
        <br />
        <div class="col-sm-6">
            <h4>研修会</h4>
            <h3>@Model.KenshuName</h3>
            <h4>を削除しますか？</h4>
        </div>
        <div class="col-sm-2">
            <a href="@Url.Action("GetSearchResult", new { actName = "戻る" })" class="btn btn-sm btn-secondary">戻る</a>
        </div>
    </div>
    <div class="row">
        <hr />
        <div class="col-md-6">
            <dl class="dl-horizontal">
                <dt>
                    【研修会名称】
                </dt>
                <dd>
                    @Model.KenshuName
                </dd>
                <dt>
                    【研修会開催日】
                </dt>
                <dd>
                    @Model.KenshuDate.ToString("yyyy/MM/dd")
                </dd>
                <dt>
                    【主催】
                </dt>
                <dd>
                    @(Model.ShusaiCd == 1 ? "内部" : "外部")
                </dd>
                <dt>
                    【主催者名】
                </dt>
                <dd>
                    @Model.ShusaiName
                </dd>
                <dt>
                    【開催形態】
                </dt>
                <dd>
                    @Model.KstyleName
                </dd>
                <dt>
                    【開催場所】
                </dt>
                <dd>
                    @Model.KenshuPlace
                </dd>
                <dt>
                    【研修会区分】
                </dt>
                <dd>
                    @(Model.FdsdCd == 1 ? "SD" : "FD")
                </dd>
            </dl>
        </div>
        <hr />
        <div class="col-md-6">
            <div class="form-group">
                【学科】
                @if (Model.GakkaNames != null)
                {
                    foreach (var name in Model.GakkaNames)
                    {
                        <h5>@name</h5>
                    }
                }
            </div>
        </div>
    </div>
    <div class="row">
        <div class="form-group">
            <div class="col-md-10">
                <hr />
                【研修開催案内】
                <h5>@Model.InfoDocu</h5>
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-10">
                <hr />
                【配布資料】
                @if (Model.Documents != null)
                {
                    foreach (var item in Model.Documents)
                    {
                        <h5>@item.DocumentName</h5>
                    }
                }
            </div>
        </div>
    </div>

    <form asp-action="DeleteConfirmed" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.KenshuCd" />

        <div class="form-actions no-color">
            <button type="submit" id="delete" class="btn btn-outline-dark btn-lg">削除</button> |
            <a href="@Url.Action("GetSearchResult", new { actName = "戻る" })" class="btn btn-sm btn-secondary">戻る</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}