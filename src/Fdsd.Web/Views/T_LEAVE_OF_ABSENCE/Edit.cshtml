@model Fdsd.Domain.Entities.T_Leave_Of_Absence
@{
    ViewData["Title"] = "Edit";
    var userList = (IEnumerable<Fdsd.Application.Common.UserDto>)ViewBag.UserList;
}
<h3>休職情報編集</h3>
<a href="@Url.Action("Index")" class="btn btn-sm btn-secondary mb-3">戻る</a>
<hr />
@Html.ValidationSummary(true, "", new { @class = "text-danger" })

<form asp-action="Edit" method="post">
    <input type="hidden" name="id" value="@Model.ID" />

    <div class="form-horizontal">
        <div class="form-group">
            <label class="control-label col-md-2">EmpName</label>
            <div class="col-md-10">
                <select name="userId" class="form-select" style="max-width:280px;" required>
                    @foreach (var u in userList)
                    {
                        if (u.UserId == (int)Model.USERID)
                        {
                            <option value="@u.UserId" selected>@u.EmpName</option>
                        }
                        else
                        {
                            <option value="@u.UserId">@u.EmpName</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">StartDate</label>
            <div class="col-md-10">
                <input type="date" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" class="form-control" style="max-width:280px;" required />
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">EndDate</label>
            <div class="col-md-10">
                <input type="date" name="endDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd") ?? "")" class="form-control" style="max-width:280px;" />
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <button type="submit" class="btn btn-outline-dark">編集</button>
            </div>
        </div>
    </div>
</form>

<div>
    <a href="@Url.Action("Index")" class="btn btn-sm btn-secondary">一覧へ戻る</a>
</div>