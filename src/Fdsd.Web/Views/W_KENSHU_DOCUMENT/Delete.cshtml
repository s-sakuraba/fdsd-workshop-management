@model Fdsd.Domain.Entities.T_Kenshu_Document
@{ViewData["Title"] = "資料削除";}

<br />
<div class="form-actions no-color">
    <div class="col-sm-6">
        <h3>【資料削除】</h3>
    </div>
    <div class="col-sm-2">
        <a href="@Url.Action("Edit", "T_KENSHU", new { id = Model.KENSHUCD })" class="btn btn-sm btn-secondary">戻る</a>
    </div>
</div>

<div class="container mt-3">
    <p class="text-danger fw-bold">以下の資料を削除します。よろしいですか？</p>
    <dl class="row">
        <dt class="col-md-3">ファイル名</dt>
        <dd class="col-md-6">@Model.DOCUMENTNAME</dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.ID" />
        <button type="submit" class="btn btn-danger">削除</button>
        <a href="@Url.Action("Edit", "T_KENSHU", new { id = Model.KENSHUCD })" class="btn btn-secondary ms-2">キャンセル</a>
    </form>
</div>